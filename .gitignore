# Local settings for provision-cli.sh — holds your personal X-API-Key and the
# API hostname. Created at runtime (chmod 600); never commit it. The committed
# template is provision.config.example.
provision.config
**/provision.config

# Terraform working dirs — provider binaries, module caches, plugin data.
# Regenerated by `terraform init`; never commit.
.terraform/
.terraformrc
terraform.rc

# Terraform state — may contain secrets and resource IDs. Use remote state.
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan artifacts and crash logs
*.tfplan
tfplan
crash.log
crash.*.log

# Local variable files — operator-specific account IDs, CIDRs, etc.
# The *.example files are the committed templates.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Backend config — operator-specific bucket / KMS / state keys.
backend.hcl
!backend.hcl.example

# Override files (local-only customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
