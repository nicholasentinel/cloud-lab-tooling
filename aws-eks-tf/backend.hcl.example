# DO NOT EDIT THIS FILE — copy to backend.hcl first, then fill in values there.
# Copy to backend.hcl and fill in from bootstrap-state/aws outputs.
# backend.hcl is gitignored.
#
#   terraform init -backend-config=backend.hcl -migrate-state
bucket       = "REPLACE-ME-cloud-lab-tfstate"
key          = "aws-eks-tf/sec-lab.tfstate"
region       = "us-west-2"
encrypt      = true
kms_key_id   = "arn:aws:kms:us-west-2:REPLACE-ME:key/REPLACE-ME"
use_lockfile = true
